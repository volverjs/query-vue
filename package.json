{
    "name": "@volverjs/query-vue",
    "type": "module",
    "version": "0.0.0",
    "packageManager": "pnpm@10.16.1",
    "description": "Repository pattern applied to a pinia store.",
    "author": "8 Wave S.r.l.",
    "license": "MIT",
    "homepage": "https://github.com/volverjs/query-vue",
    "repository": {
        "type": "git",
        "url": "https://github.com/volverjs/query-vue"
    },
    "bugs": {
        "url": "https://github.com/volverjs/query-vue/issues"
    },
    "keywords": [
        "repository",
        "pinia"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        },
        "./src/*": "./src/*",
        "./dist/*": "./dist/*"
    },
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "typesVersions": {
        "*": {
            "*": [
                "dist/index.d.ts"
            ]
        }
    },
    "files": [
        "*.d.ts",
        "dist",
        "src"
    ],
    "engines": {
        "node": ">= 16.x"
    },
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "type-check": "tsc --noEmit",
        "dev": "vite build --watch",
        "build": "vite build",
        "test": "pnpm run test-vitest",
        "test-vitest": "vitest run",
        "test-vitest-watch": "vitest",
        "credits": "npx @opengovsg/credits-generator"
    },
    "peerDependencies": {
        "@volverjs/data": "^2.0.1",
        "@vueuse/core": "^13.0.x",
        "pinia": "^3.0.x",
        "vue": "^3.5.x"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^5.3.0",
        "@nabla/vite-plugin-eslint": "^2.0.6",
        "@pinia/testing": "^1.0.2",
        "@types/node": "^24.5.0",
        "@vitejs/plugin-vue": "^6.0.1",
        "@volverjs/data": "^2.0.3",
        "@vue/test-utils": "^2.4.6",
        "@vueuse/core": "^13.9.0",
        "copy": "^0.3.2",
        "eslint": "^9.35.0",
        "happy-dom": "^19.0.2",
        "pinia": "^3.0.3",
        "typescript": "5.9.3",
        "vite": "^7.1.5",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4",
        "vitest-fetch-mock": "^0.4.5",
        "vue": "^3.5.21",
        "vue-tsc": "^3.0.7"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
